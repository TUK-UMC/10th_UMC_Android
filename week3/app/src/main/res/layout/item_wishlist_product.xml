<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp">

    <ImageView
        android:id="@+id/item_wishlist_iv"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/ic_launcher_background" />

    <TextView
        android:id="@+id/item_wishlist_name_tv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Nike Air Force 1 '07"
        android:textColor="#000000"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/item_wishlist_iv" /> <TextView
        android:id="@+id/item_wishlist_category_tv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Women's Shoes"
        android:textColor="#888888"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/item_wishlist_name_tv" />

    <TextView
        android:id="@+id/item_wishlist_colors_tv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="5 Colours"
        android:textColor="#888888"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/item_wishlist_category_tv" />

    <TextView
        android:id="@+id/item_wishlist_price_tv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:text="US$115"
        android:textColor="#000000"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/item_wishlist_colors_tv" />

    <ImageView
        android:id="@+id/item_wishlist_heart_iv"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:padding="4dp"
        android:src="@drawable/ic_nav_wishlist"
        app:tint="#FF0000"
        app:layout_constraintEnd_toEndOf="@id/item_wishlist_iv"
        app:layout_constraintTop_toTopOf="@id/item_wishlist_iv" />

</androidx.constraintlayout.widget.ConstraintLayout>